    /* End Chatbot all default msgs */

    function initializeIntlTelInput(input) {
        window.intlTelInput(input, {
            hiddenInput: input.id,
            separateDialCode: true,
            formatOnDisplay: true,
            utilsScript: "https://cdn.jsdelivr.net/npm/intl-tel-input@18.2.1/build/js/utils.js",
        });
        input.dataset.intlTelInit = "true"; // Prevent reinitialization
    }

    function check_chatbot_user_status() {
        if (localStorage.getItem('chat_bot_client_data') == null) {
            chat_first_msg();
            $('#client-info-form, #chat-form').show();

        } else {
            let userData = JSON.parse(localStorage.getItem('chat_bot_client_data'));
            let clientName = userData.client_name;
            chat_welcome_back_msg();
            $('#welcome-back-msg .client-name-text').text(clientName);
            chat_options_list_msg();
            $('#chat-form').show();
        }
        const phoneInput = document.getElementById("client_phone");
        console.log(phoneInput);
        if (phoneInput) {
            if (phoneInput.isConnected) {
                initializeIntlTelInput(phoneInput);
            } else {
                $("#client_phone").each(function () {
                    initializeIntlTelInput(this);
                });
            }
        }
        else {
            console.log('no phone input found');
        }
    }


    $(document).ready(function () {
        //Allow telephone characters only
        $('#client_phone').on('keypress', function (event) {
            const allowedChars = /^[0-9+\-\(\)\s]$/;
            const key = String.fromCharCode(event.which);

            if (!allowedChars.test(key)) {
                event.preventDefault();
            }
        });
    });
    $(document).ready(function () {
        // Return to first chatbot info form if it is not same user
        $(document).on('click', '#vizbot .chat-body .system-msg .form-back-btn', function (e) {
            e.preventDefault();
            $('#vizbot #chat-screen #welcome-back-msg, #vizbot #chat-screen .options-list-msg').remove();
            chat_first_msg();
            $('#vizbot #client-info-form, #vizbot #chat-form').show();
        });
        //Continue chat on clicking 'drop a msg' button in chatbot
        $(document).on('click', '#vizbot .drop-msg-btn', function (e) {
            e.preventDefault();
            clearInterval(timerInterval);
            clearInterval(idleInterval);
            $('#vizbot .chat-close-timer,#vizbot .chat-close-btns,#vizbot .chat-close-btns-user').hide();
            $('#vizbot #chat-form').show();
            $('#vizbot #chat-form #chat-reply-input').focus();
            startIdleTimer();
        });
        //Go to chatbot rating screen on cliking 'end chat button'
        $(document).on('click', '#vizbot .end-chat-btn', function (e) {
            e.preventDefault();
            clearInterval(timerInterval);
            clearInterval(idleInterval);
            $('#vizbot #chat-body,#vizbot #client-info-form,#vizbot .chat-close-timer,#vizbot .chat-close-btns,#vizbot .chat-close-btns-user,#vizbot .options-list-msg').hide();
            $('#vizbot #ratings-form').show();
        });
        // send response against four options
        $(document).on('click', '#vizbot .options-list-msg ul li .btn', function (e) {
            let btnText = $(this).text();
            var time_now = getFormattedTime();
            var history = [];
            var user_post = '<div class="client-msg"><div class="text" title="' + time_now + '"><p>' + btnText + '</p></div><p class="date-time">' + time_now + '</p></div>';
            $('.date-time').remove();
            $('#vizbot .chat-body').append(user_post);
            $(this).find('textarea').val('');
            scrollToBottom();
            $(this).find('#chat-reply-input').val('');
            var loader = '<div class="system-msg loader-row-msg"><div class="d-flex"><div class="img"><img src="{{ asset('public/assets/img/vizbot-icon.png')}}" alt="Vizbot Image"></div> <div class="loader-dots"><div class="loader-dot"></div><div class="loader-dot"></div><div class="loader-dot"></div></div></div></div>';
            $('#vizbot .options-list-msg').remove()
            $('#vizbot .chat-body').append(loader);
            clearInterval(timerInterval);
            clearInterval(idleInterval);
            scrollToBottom();
            $.ajax({
                url: app_ajax_chat,  // Your endpoint
                type: "POST",  // HTTP method
                contentType: "application/json",  // Ensures the server knows it's JSON
                data: JSON.stringify({  // Serialize the data into JSON format
                    user_query: btnText,  // Include your user query
                    history: history  // Ensure 'history' is defined and valid
                }),
                success: function (response) {
                    $('.date-time,#vizbot .chat-body .loader-row-msg').remove();
                    var time_reply = getFormattedTime();
                    var formattedmsg = addAnchorTagsToLinks(response.response);
                    var formattedmsg = addAnchorTagsToLinks(response.response);
                    var user_reply = '<div class="system-msg"><div class="d-flex"><div class="img"><img src="{{ asset('public/assets/img/vizbot-icon.png')}}" alt="Vizbot Image"></div><div class="text-box"><div class="text" title="' + time_reply + '"><p>' + formattedmsg + '</p></div><p class="date-time">' + time_reply + '</p></div></div></div>';
                    $('#vizbot .chat-body').append(user_reply);
                    startIdleTimer();
                    scrollToBottom();
                },
                error: function (xhr, status, error) {
                    console.log("Request failed:", error);
                }
            });
        });
    });

    // Track AJAX progress using global AJAX events
    let isAjaxInProgress = false;
    $(document).on('ajaxStart', () => isAjaxInProgress = true);
    $(document).on('ajaxStop', () => isAjaxInProgress = false);

    // Save chatbot HTML and form state to localStorage
    function saveChatbotHTML() {
        const chatbotElement = $('#vizbot').clone(); // Clone the element to avoid modifying the DOM

        chatbotElement.find('.iti').each(function () {

            const originalInput = `<input type="tel" class="form-control" id="client_phone" placeholder="(123) 343-3432">`;
            $(this).replaceWith(originalInput); // Replace the .iti div with the original input
        });

        const chatbotHTML = chatbotElement.html();
        const chatbotState = {
            html: chatbotHTML,
        };

        localStorage.setItem('chatbot_state', JSON.stringify(chatbotState)); // Save full state to localStorage
        console.log("Chatbot content and state saved to localStorage");
    }


    // Restore chatbot HTML and reinitialize components
    function restoreChatbotHTML() {
        const chatbotState = localStorage.getItem('chatbot_state');
        if (chatbotState) {
            const state = JSON.parse(chatbotState);
            $('#vizbot').html(state.html); // Restore HTML
            console.log("Chatbot content and state restored from localStorage");

            setTimeout(() => {
                if ($.trim($('#vizbot #chat-body').html()) === '') {
                    console.log('chat body empty');
                    check_chatbot_user_status(); // Ensure the user status is checked
                } else {

                    const phoneInput = document.getElementById("client_phone");
                    console.log(phoneInput);
                    if (phoneInput) {
                        console.log('phone input found');
                        if (phoneInput.isConnected) {
                            initializeIntlTelInput(phoneInput);

                            console.log('static phone');
                        } else {
                            $("#client_phone").each(function () {
                                initializeIntlTelInput(this);
                                console.log('dynamic phone');
                            });
                        }
                    }
                    else {
                        console.log('no phone input found');
                    }
                    if (!($('#vizbot #ratings-form').is(":visible"))) {
                        if (($('#vizbot .chat-close-timer').is(":visible"))) {
                            resumeStoppedTimer();
                        } else {
                            const length = $('#vizbot #chat-body .client-msg').length;
                            if (length > 0) {
                                startIdleTimer(); // Start idle timer if there are messages
                            }
                        }
                    }
                }
            }, 500); // Adjusted delay to allow for content restoration
            scrollToBottom(); // Ensure the page is scrolled to the bottom
        }
    }
    function resumeStoppedTimer() {
        if (timerInterval) return; // Prevent multiple intervals.

        let timerValueText = $('#vizbot .chat-close-timer p').text().trim();
        let [hours, minutes, seconds] = timerValueText.split(':').map(Number);
        let timerValue = (hours * 3600 + minutes * 60 + seconds) * 1000;
        let startTime = performance.now();

        timerInterval = setInterval(() => {
            let elapsed = performance.now() - startTime;
            let remainingTime = Math.max(timerValue - elapsed, 0);

            let totalSeconds = Math.floor(remainingTime / 1000);
            let currentHours = Math.floor(totalSeconds / 3600);
            let currentMinutes = Math.floor((totalSeconds % 3600) / 60);
            let currentSeconds = totalSeconds % 60;
            let formattedTime = `${currentHours.toString().padStart(2, '0')}:${currentMinutes.toString().padStart(2, '0')}:${currentSeconds.toString().padStart(2, '0')}`;

            $('#vizbot .chat-close-timer p').text(formattedTime);

            if (remainingTime <= 0) {
                clearInterval(timerInterval);
                timerInterval = null; // Reset the interval to allow restarting if needed.
                scrollToBottom();
                saveChatbotHTML();
                $('#vizbot #chat-body').hide();
                chat_end_msg();
                $('.date-time').remove();
                sendVizbotHTMLForm();
            }
        }, 1000);
    }
    // Save chatbot content to localStorage when changes occur or the tab is closed
    function saveChatbotContent() {
        const chatbotContent = $('#vizbot').html();
        localStorage.setItem("chatbotContent", chatbotContent);
        localStorage.setItem("chatbotLastActive", Date.now()); // Save a timestamp for the last update
        console.log("Chatbot content saved.");
    }

    window.addEventListener("beforeunload", saveChatbotContent);

    // Restore chatbot content when a tab is loaded
    document.addEventListener("DOMContentLoaded", function () {
        const savedContent = localStorage.getItem("chatbotContent");
        if (savedContent) {
            console.log("Restoring chatbot content from localStorage...");
            $('#vizbot').html(savedContent);
            restoreChatbotHTML();
        } else {
            console.log("No existing chatbot content found.");
        }
    });

    // Synchronize content across tabs using the storage event
    window.addEventListener("storage", function (event) {
        if (event.key === "chatbotContent") {
            console.log("Chatbot content updated in another tab. Synchronizing...");
            const updatedContent = localStorage.getItem("chatbotContent");
            $('#vizbot').html(updatedContent);
            restoreChatbotHTML();
        }
    });

    // // Update form state after loading chatbot content
    function updateForm() {
        const chatbotState = localStorage.getItem('chatbot_state');
        if (chatbotState != null) {
            const state = JSON.parse(chatbotState);
            $('#vizbot').html(state.html);

            setTimeout(() => {
                if ($.trim($('#vizbot #chat-body').html()) === '') {
                    console.log('chat body empty');
                    check_chatbot_user_status(); // Ensure the user status is checked
                } else {
                    if (!($('#vizbot #ratings-form').is(":visible"))) {
                        if (($('#vizbot .chat-close-timer').is(":visible"))) {
                            resumeStoppedTimer();
                        } else {
                            const length = $('#vizbot #chat-body .client-msg').length;
                            if (length > 0) {
                                startIdleTimer(); // Start idle timer if there are messages
                            }
                        }
                    }
                }
            }, 1000); // Adjust delay as needed
        } else {
            check_chatbot_user_status(); // If no state is found, check user status
        }
        scrollToBottom(); // Ensure page scroll is correct
    }

    // Open the chatbot form and initialize the state
    function openForm() {

        document.getElementById("vizbot").style.display = "block"; // Show the chat window

        // Add a delay of 500ms before showing and adding the class
        setTimeout(() => {
            $("#vizbot .lds-roller-footer").show();
        }, 100);

        if (openMinimzieChat == 0) {
            openMinimzieChat = 1;
            updateForm(); // Initialize the form state
        }
        setTimeout(() => {
            $("#vizbot .lds-roller-footer").hide();
        }, 500);
    }

    function addAnchorTagsToLinks(text) {
        if (typeof text !== 'string') {
            console.error('Input must be a valid string.');
        if (typeof text !== 'string') {
            console.error('Input must be a valid string.');
            return '';
        }
        
        const regex = /https?:\/\/[a-zA-Z0-9-._~:/?#[\]@!$&'()*+,;=]+/g;
        return text.replace(regex, (url) => {
            const cleanedUrl = url.endsWith('.') ? url.slice(0, -1) : url;
            return `<a href="${cleanedUrl}" target="_blank">${cleanedUrl}</a>`;
            const cleanedUrl = url.endsWith('.') ? url.slice(0, -1) : url;
            return `<a href="${cleanedUrl}" target="_blank">${cleanedUrl}</a>`;
        });
    }

</script>